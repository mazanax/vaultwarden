# ---- Vaultwarden (base image, examples) -------------------------------------
# ADMIN_TOKEN=...
# DOMAIN=https://vault.example.com
# SIGNUPS_ALLOWED=false

# ---- Backup subsystem -------------------------------------------------------
# Backups are ENABLED only when ALL of the required variables below are set.
# Leave them empty/unset to run vaultwarden without scheduled backups.

# -- Required --
# age PUBLIC recipient key (age1...). Decryption key is kept OUTSIDE the container.
# Multiple recipients may be given, separated by spaces.
BACKUP_AGE_KEY=age1qqqqqexamplepublickeyreplaceme

# S3-compatible storage
BACKUP_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
BACKUP_S3_BUCKET=my-vaultwarden-backups
BACKUP_S3_ACCESS_KEY_ID=AKIA...
BACKUP_S3_SECRET_ACCESS_KEY=...

# -- Optional --
# Cron expression for the backup job (default: hourly)
BACKUP_SCHEDULE=0 * * * *
# Cron expression for the retention/cleanup job (default: daily 03:30)
BACKUP_RETENTION_SCHEDULE=30 3 * * *
# How many most-recent backups to keep (default: 24)
BACKUP_RETENTION_COUNT=24
# Object-key prefix inside the bucket (default: none). Trailing slash optional.
BACKUP_S3_PATH_PREFIX=vaultwarden/
# S3 region (default: us-east-1)
BACKUP_S3_REGION=us-east-1
# rclone S3 provider (default: Other). E.g. AWS, Minio, Wasabi, Cloudflare, Ceph...
BACKUP_S3_PROVIDER=Other
